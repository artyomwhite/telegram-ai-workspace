generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

enum ActivityType {
  CREATED
  UPDATED
  DELETED
  COMPLETED
  CONNECTED
  DISCONNECTED
  LOGIN
  OTHER
}

enum AIRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  telegramConnections TelegramConnection[]
  contacts            Contact[]
  companies           Company[]
  tasks               Task[]
  notes               Note[]
  messages            Message[]
  reminders           Reminder[]
  aiRequests          AIRequest[]
  activityLogs        ActivityLog[]

  @@map("users")
}

model TelegramConnection {
  id               String   @id @default(cuid())
  userId           String
  telegramUserId   String   @unique
  telegramUsername String?
  chatId           String
  isActive         Boolean  @default(true)
  connectedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_connections")
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  firstName String
  lastName  String
  email     String?
  phone     String?
  position  String?
  companyId String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  tasks   Task[]

  @@index([userId])
  @@index([companyId])
  @@map("contacts")
}

model Company {
  id          String   @id @default(cuid())
  userId      String
  name        String
  industry    String?
  website     String?
  email       String?
  phone       String?
  address     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]
  tasks    Task[]

  @@index([userId])
  @@map("companies")
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  contactId   String?
  companyId   String?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  notes    Note[]
  reminders Reminder[]

  @@index([userId])
  @@index([status])
  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("notes")
}

model Message {
  id               String   @id @default(cuid())
  userId           String
  telegramUserId   String?
  direction        String
  content          String
  telegramMessageId String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("messages")
}

model Reminder {
  id          String         @id @default(cuid())
  userId      String
  taskId      String?
  title       String
  message     String?
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  sentAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([remindAt, status])
  @@map("reminders")
}

model AIRequest {
  id        String          @id @default(cuid())
  userId    String
  prompt    String
  response  String?
  model     String          @default("gpt-4")
  status    AIRequestStatus @default(PENDING)
  tokens    Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_requests")
}

model ActivityLog {
  id          String       @id @default(cuid())
  userId      String
  type        ActivityType
  entityType  String
  entityId    String?
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
